{
  "name": "01-mediasoup-rtc",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev:app": "pnpm --filter @rtc/app dev",
    "dev:mediasoup": "pnpm --filter @rtc/mediasoup dev",
    "typecheck:mediasoup": "pnpm --filter @rtc/mediasoup typecheck",
    "prepare": "git config core.hooksPath .githooks",
    "build": "pnpm --filter @rtc/mediasoup build",
    "check:precommit": "pnpm build"
  }
}
